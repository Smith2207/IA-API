# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# CORS (coma-separado; * solo desarrollo)
CORS_ORIGINS=http://localhost:3000,https://tu-dominio.vercel.app

# Modelos (opcional)
YOLO_MODEL=yolov8n.pt
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai

# API
LOG_LEVEL=INFO
API_PREFIX=
# API_KEY=opcional; si no se define, no se exige X-API-Key

# Búsqueda
SEARCH_TOP_K=5
SIMILARITY_MIN_PERCENT=0
